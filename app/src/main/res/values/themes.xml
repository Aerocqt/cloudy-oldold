<resources>
    <!-- Inherit the SESL/OneUI app theme from the tribalfs appcompat + material fork.
         DayNight gives the OneUI light/dark surfaces automatically. -->
    <style name="OneUITheme" parent="Theme.SeslMaterial.DayNight">
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Cloudy.SectionTitle" parent="">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <style name="Cloudy.CategoryHeader" parent="">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">8dp</item>
    </style>
</resources>
