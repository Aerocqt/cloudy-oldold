<resources>
    <!--
        OneUITheme + OneUI.* button styles come from the oneui-design library; not redefined.
        This overlay only forces the OneUI system font family across the app.

        "sec" is Samsung's system font alias - on OneUI 8 devices it resolves to One UI Sans
        (the library itself uses android:fontFamily="sec" internally). One UI Sans is a
        proprietary Samsung font and cannot be bundled in the APK, so on non-Samsung devices
        this gracefully falls back to the platform sans-serif.
    -->
    <style name="Theme.Cloudy" parent="OneUITheme">
        <item name="android:fontFamily">sec</item>
        <item name="fontFamily">sec</item>
        <item name="android:textViewStyle">@style/Cloudy.TextView</item>
        <item name="android:buttonStyle">@style/Cloudy.Button</item>
    </style>

    <style name="Cloudy.TextView" parent="android:Widget.Material.TextView">
        <item name="android:fontFamily">sec</item>
    </style>
    <style name="Cloudy.Button" parent="android:Widget.Material.Button">
        <item name="android:fontFamily">sec</item>
    </style>
</resources>
