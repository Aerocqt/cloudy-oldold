<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="always"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== Status ===== -->
        <dev.oneuiproject.oneui.widget.Separator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sep_status" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_oui_card"
            android:layout_marginHorizontal="@dimen/oui_card_margin_h"
            android:orientation="vertical">

            <dev.oneuiproject.oneui.widget.CardItemView
                android:id="@+id/rowStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:showTopDivider="false"
                app:icon="@drawable/ic_cloudy_settings"
                app:title="@string/status_checking"
                tools:ignore="ContentDescription" />

            <ProgressBar
                android:id="@+id/downloadBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:max="100"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- ===== Available build ===== -->
        <dev.oneuiproject.oneui.widget.Separator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sep_available" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_oui_card"
            android:layout_marginHorizontal="@dimen/oui_card_margin_h"
            android:orientation="vertical">

            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteVersion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:showTopDivider="false" app:title="@string/f_version" tools:summary="-" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowBuildDate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_build_date" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteAndroid"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_android" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteSecurity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_patch" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteFingerprint"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_fingerprint" app:summaryMaxLines="3" />
        </LinearLayout>

        <!-- ===== Changelog ===== -->
        <dev.oneuiproject.oneui.widget.Separator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sep_changelog" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_oui_card"
            android:layout_marginHorizontal="@dimen/oui_card_margin_h"
            android:orientation="vertical">

            <TextView
                android:id="@+id/changelog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingVertical="18dp"
                android:lineSpacingExtra="5dp"
                android:textSize="15sp"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

        <!-- ===== This device ===== -->
        <dev.oneuiproject.oneui.widget.Separator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sep_device" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_oui_card"
            android:layout_marginHorizontal="@dimen/oui_card_margin_h"
            android:orientation="vertical">

            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowInstalledVersion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:showTopDivider="false" app:title="@string/f_installed" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowDeviceModel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_model" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowAndroid"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_android" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowSecurity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_patch" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowFingerprint"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_fingerprint" app:summaryMaxLines="3" />
            <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowKernel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:title="@string/f_kernel" app:summaryMaxLines="3" />
        </LinearLayout>

        <!-- ===== Actions ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp">

            <Button
                android:id="@+id/btnCheck"
                style="@style/OneUI.ButtonStyleOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_check" />

            <Button
                android:id="@+id/btnDownload"
                style="@style/OneUI.ContainedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:enabled="false"
                android:text="@string/btn_download" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
