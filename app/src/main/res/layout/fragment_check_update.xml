<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <TextView android:id="@+id/status" style="@style/Cloudy.SectionTitle"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Checking..." />

        <ProgressBar android:id="@+id/progress" style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true" android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView style="@style/Cloudy.CategoryHeader" android:text="Available build"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Version"/>
            <TextView android:id="@+id/rowRemoteVersion" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Build date"/>
            <TextView android:id="@+id/rowBuildDate" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Android version"/>
            <TextView android:id="@+id/rowRemoteAndroid" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Security patch"/>
            <TextView android:id="@+id/rowRemoteSecurity" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Build fingerprint"/>
            <TextView android:id="@+id/rowRemoteFingerprint" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <TextView style="@style/Cloudy.CategoryHeader" android:text="Changelog"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="24dp" app:cardElevation="0dp">
            <TextView android:id="@+id/changelog" android:padding="20dp" android:lineSpacingExtra="4dp"
                android:textSize="15sp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </androidx.cardview.widget.CardView>

        <TextView style="@style/Cloudy.CategoryHeader" android:text="This device"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Installed version"/>
            <TextView android:id="@+id/rowInstalledVersion" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Device model"/>
            <TextView android:id="@+id/rowDeviceModel" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Android version"/>
            <TextView android:id="@+id/rowAndroid" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Security patch"/>
            <TextView android:id="@+id/rowSecurity" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Build fingerprint"/>
            <TextView android:id="@+id/rowFingerprint" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <LinearLayout style="@style/Cloudy.Row">
            <TextView style="@style/Cloudy.Row.Label" android:text="Kernel version"/>
            <TextView android:id="@+id/rowKernel" style="@style/Cloudy.Row.Value" tools:text="-"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"/>
        <ProgressBar android:id="@+id/downloadBar" style="?android:attr/progressBarStyleHorizontal"
            android:max="100" android:layout_marginTop="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnCheck"
            android:layout_marginTop="12dp" android:text="Check for updates"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnDownload"
            android:layout_marginTop="8dp" android:enabled="false" android:text="Download and install"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
