<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <TextView android:id="@+id/status" style="@style/Cloudy.SectionTitle"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Checking…" />

        <ProgressBar android:id="@+id/progress" style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true" android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView style="@style/Cloudy.CategoryHeader" android:text="Available build"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteVersion" app:title="Version"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowBuildDate" app:title="Build date"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteAndroid" app:title="Android version"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteSecurity" app:title="Security patch"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowRemoteFingerprint" app:title="Build fingerprint"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <TextView style="@style/Cloudy.CategoryHeader" android:text="Changelog"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="26dp" app:cardElevation="0dp" app:cardBackgroundColor="?attr/colorSurfaceContainer">
            <TextView android:id="@+id/changelog" android:padding="20dp" android:lineSpacingExtra="4dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </androidx.cardview.widget.CardView>

        <TextView style="@style/Cloudy.CategoryHeader" android:text="This device"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowDeviceModel" app:title="Device model"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowAndroid" app:title="Android version"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowSecurity" app:title="Security patch"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowFingerprint" app:title="Build fingerprint"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rowKernel" app:title="Kernel version"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <ProgressBar android:id="@+id/downloadBar" style="?android:attr/progressBarStyleHorizontal"
            android:max="100" android:layout_marginTop="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnCheck" style="@style/Widget.SeslMaterial.Button.Tonal"
            android:layout_marginTop="12dp" android:text="Check for updates"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnDownload" style="@style/Widget.SeslMaterial.Button"
            android:layout_marginTop="8dp" android:enabled="false" android:text="Download and install"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
