<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout android:orientation="vertical" android:padding="16dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            app:cardCornerRadius="28dp" app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <ImageView android:src="@drawable/ic_cloudy_settings"
                    android:layout_width="72dp" android:layout_height="72dp"/>
                <TextView android:id="@+id/name" style="@style/Cloudy.SectionTitle"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/handle" android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView style="@style/Cloudy.CategoryHeader" android:text="Details"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/rom" app:title="ROM"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <dev.oneuiproject.oneui.widget.CardItemView android:id="@+id/device" app:title="Device"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <Button android:id="@+id/btnTelegram" style="@style/Widget.SeslMaterial.Button.Tonal"
            android:layout_marginTop="16dp" android:text="Telegram"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnDonate" style="@style/Widget.SeslMaterial.Button.Tonal"
            android:layout_marginTop="8dp" android:text="Donate"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
