<?xml version="1.0" encoding="utf-8"?>
<!--
    OneUI 8 shell with an 8.5-style FLOATING bottom navigation bar:
      ToolbarLayout          - collapsing large title + subtitle
      FragmentContainerView  - main_content (adaptive margins handled by the lib)
      BottomFloatingLayout   - footer; floats the tab bar with margins + pill background
-->
<dev.oneuiproject.oneui.layout.ToolbarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbarLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:expandable="true"
    app:expanded="true"
    app:title="@string/app_name"
    app:subtitle="@string/settings_entry_summary">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_location="main_content" />

    <dev.oneuiproject.oneui.widget.BottomFloatingLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        app:maxChildWidth="520dp"
        app:layout_location="footer">

        <dev.oneuiproject.oneui.widget.BottomTabLayout
            android:id="@+id/bottomTab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_oui_float_nav"
            android:elevation="6dp"
            app:menu="@menu/menu_bottom_tabs" />
    </dev.oneuiproject.oneui.widget.BottomFloatingLayout>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
