<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Only granted when Cloudy is installed as a privileged/system app inside the ROM. -->
    <uses-permission android:name="android.permission.REBOOT"
        tools:ignore="ProtectedPermissions" xmlns:tools="http://schemas.android.com/tools" />
    <uses-permission android:name="android.permission.RECOVERY"
        tools:ignore="ProtectedPermissions" xmlns:tools="http://schemas.android.com/tools" />

    <application
        android:name=".CloudyApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/OneUITheme">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/OneUITheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ============================================================
                 SAMSUNG SETTINGS DASHBOARD INJECTION
                 ============================================================
                 This makes "Cloudy / Check update of LumiROM" appear as a
                 native row inside the stock Settings app.

                 IMPORTANT: Samsung's SettingsProvider only indexes activities
                 whose package lives in the privileged system image
                 (/system/priv-app or /system_ext/priv-app) and is on the
                 platform allow-list. As the LumiROM maintainer you satisfy
                 this by bundling Cloudy in the ROM. A normally sideloaded
                 user-app will simply be ignored by the indexer (no crash,
                 it just won't show in Settings).
                 ============================================================ -->
            <intent-filter>
                <action android:name="com.android.settings.action.EXTRA_SETTINGS" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.samsung.settings.action.EXTRA_SETTINGS" />
            </intent-filter>

            <!-- Which top-level Settings group to slot into. "…category.device"
                 lands it under the "About/Software update" cluster on OneUI. -->
            <meta-data
                android:name="com.android.settings.category"
                android:value="com.android.settings.category.ia.device" />
            <meta-data
                android:name="com.samsung.settings.category"
                android:value="com.samsung.settings.category.software_update" />

            <!-- Visible title + subtext shown by the Settings indexer. -->
            <meta-data
                android:name="com.android.settings.title"
                android:resource="@string/settings_entry_title" />
            <meta-data
                android:name="com.android.settings.summary"
                android:resource="@string/settings_entry_summary" />
            <meta-data
                android:name="com.android.settings.icon"
                android:resource="@drawable/ic_cloudy_settings" />
            <!-- Sort order within the group (lower = higher up). -->
            <meta-data
                android:name="com.samsung.settings.order"
                android:value="150" />
        </activity>

        <!-- Bound service that runs shell work in the root context via libsu. -->
        <service
            android:name=".ota.RootService"
            android:exported="false" />
    </application>
</manifest>
