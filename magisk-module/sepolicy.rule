# Allow the Cloudy app domain to do the specific things the flasher needs, and nothing more.
# Magisk/KernelSU load this at boot (magiskpolicy --live equivalent).
#
# NOTE: on most builds a third-party app runs in the generic untrusted_app domain, so these
# rules are intentionally scoped to the operations Cloudy performs, not a blanket allow.

# Write the recovery command file so recovery applies the OTA on next boot.
allow untrusted_app cache_file dir  { search write add_name }
allow untrusted_app cache_file file { create open write getattr setattr }

# Read block devices by-name (to validate the target partition exists before any write).
allow untrusted_app block_device dir  { search read }
allow untrusted_app block_device lnk_file { read getattr }

# Trigger a reboot into recovery.
allow untrusted_app power_service service_manager find
allow untrusted_app system_server binder call
